# =============================================================================
# SentinelAI - Environment Configuration
# Copy this file to .env and update values for your environment.
# =============================================================================

# Application
APP_NAME=SentinelAI
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# PostgreSQL
POSTGRES_URL=postgresql://sentinel:sentinel_secret@localhost:5432/sentinelai

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j_secret

# AI Services (reserved for future modules)
GEMINI_API_KEY=your-gemini-api-key-here

# Security
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production

# Logging
LOG_LEVEL=INFO

# Ingestion
MAX_UPLOAD_SIZE_MB=10
MIN_TEXT_LENGTH=10
ARTICLE_FETCH_TIMEOUT=30
ARTICLE_USER_AGENT=SentinelAI/0.1.0 (+https://sentinelai.local)
DEFAULT_COUNTRY=IN
OCR_ENABLED=true
